# GitHub Personal Access Token with repo read scope on hit-pay/hitpay-core
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Loops API key (from app.loops.so/settings/api)
LOOPS_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Loops transactional email template ID (create one in Loops dashboard)
LOOPS_TRANSACTIONAL_ID=xxxxxxxxxxxxxxxx

# Set to "true" to generate HTML without sending
DRY_RUN=false
